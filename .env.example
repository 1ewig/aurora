# Database Connection
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# InsForge Public BaaS Keys
NEXT_PUBLIC_INSFORGE_URL="https://your-project.database.insforge.app"
NEXT_PUBLIC_INSFORGE_ANON_KEY="your-public-anon-key"
INSFORGE_API_KEY="your-admin-service-key"

# InsForge JWT Secret (get with: npx @insforge/cli secrets get JWT_SECRET)
INSFORGE_JWT_SECRET="your-insforge-jwt-secret"

# Admin Access (private server-side variable)
ADMIN_EMAILS="admin@example.com"

# Better Auth
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Brevo SMTP (for transactional emails — verification, password reset)
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER="your-brevo-smtp-email"
BREVO_SMTP_PASS="your-brevo-smtp-key"
BREVO_FROM_EMAIL="noreply@yourdomain.com"
BREVO_FROM_NAME="Aurora"

# Lemon Squeezy Sandbox
LEMON_SQUEEZY_API_KEY="your-ls-test-api-key"
LEMON_SQUEEZY_STORE_ID="your-ls-test-store-id"
LEMON_SQUEEZY_WEBHOOK_SECRET="your-ls-test-webhook-signing-secret"
NEXT_PUBLIC_LS_ORDER_VARIANT_ID="your-ls-test-product-variant-id"
